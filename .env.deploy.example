# Git revision to deploy. The script requires local HEAD to match this remote branch.
DEPLOY_REMOTE=origin
DEPLOY_BRANCH=main

# Lightsail / backend
DEPLOY_BACKEND=true
DEPLOY_SSH_HOST=api.othuoc.space
DEPLOY_SSH_USER=ubuntu
DEPLOY_SSH_PORT=22
DEPLOY_SSH_KEY=${HOME}/.ssh/LightsailDefaultKey-ap-southeast-1.pem
DEPLOY_REMOTE_APP_DIR=/var/www/haiku-othuoc
DEPLOY_PM2_APP_NAME=haiku-api
DEPLOY_REMOTE_HEALTH_URL=http://127.0.0.1:4000/api/health

# Create a PostgreSQL backup before pulling and restarting the API.
DEPLOY_DB_BACKUP=true

# S3 / CloudFront frontend
DEPLOY_FRONTEND=true
FRONTEND_S3_BUCKET=haiku-othuoc
FRONTEND_S3_PROTECTED_PREFIXES=ops
CLOUDFRONT_DISTRIBUTION_ID=EP23DSG9TP2CV
CLOUDFRONT_WAIT=true
FRONTEND_HEALTH_URL=https://haiku.othuoc.space

# Optional AWS CLI settings
AWS_PROFILE=
AWS_REGION=ap-southeast-1
